# HYDRA Configuration
# Copy this to .env and fill in your values. .env 는 git 커밋 금지.
# 비밀 생성 명령: openssl rand -base64 32  (또는 openssl rand -base64 64)

# === 필수 시크릿 (Phase 1 에서 사용) ===

# DB 암호화 키 (accounts.password / totp_secret AES 암호화용)
DB_CRYPTO_KEY=CHANGE_ME_openssl_rand_base64_32

# 어드민 세션 JWT 서명 키
JWT_SECRET=CHANGE_ME_openssl_rand_base64_64

# 워커 enrollment 토큰 서명 키 (JWT_SECRET 과 분리)
ENROLLMENT_SECRET=CHANGE_ME_openssl_rand_base64_32

# === 환경 URL ===
# Mac dev: http://localhost:8000
# VPS prod: https://api.hydra.com
SERVER_URL=http://localhost:8000

# CORS 허용 도메인 (쉼표 구분, admin UI 주소들)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://admin.hydra.com

# === DB 연결 ===
# Mac dev (SQLite): sqlite:///data/hydra.db
# VPS prod (PostgreSQL): postgresql://hydra:PASS@localhost/hydra_prod
DATABASE_URL=sqlite:///data/hydra.db

# Alembic 용 (DATABASE_URL 과 같아도 OK)
POSTGRES_USER=hydra
POSTGRES_PASSWORD=hydra_secret
POSTGRES_DB=hydra_prod
POSTGRES_PORT=5432
DB_URL=postgresql+psycopg2://hydra:hydra_secret@localhost:5432/hydra

# === 파일 저장 경로 ===
# Mac dev: ./data/avatars
# VPS prod: /var/hydra/avatars
AVATAR_STORAGE_DIR=./data/avatars

# === 외부 API 키 ===
# Claude API
CLAUDE_API_KEY=sk-ant-...

# YouTube Data API (2+ keys for rotation)
YOUTUBE_API_KEY_1=AIza...
YOUTUBE_API_KEY_2=AIza...

# 2Captcha
TWOCAPTCHA_API_KEY=...

# Telegram Bot (선택)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Discord Webhook (알림용 — Phase 3)
DISCORD_WEBHOOK_URL=

# AdsPower (로컬 API)
ADSPOWER_API_URL=http://local.adspower.net:50325

# === 기존 워커 설정 (하위 호환) ===
WORKER_TOKEN_SECRET=change-this-to-random-string
SERVER_PORT=8000
