powershell -NoProfile -ExecutionPolicy Bypass -Command "if(-not([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)){Start-Process -FilePath '%~f0' -Verb RunAs;exit}; Add-Type -AssemblyName Microsoft.VisualBasic; $t=[Microsoft.VisualBasic.Interaction]::InputBox('Paste enrollment token (eyJ...)','HYDRA Worker',''); if([string]::IsNullOrWhiteSpace($t)){Write-Host 'No token. Aborted.' -ForegroundColor Yellow;pause;exit 1}; $u='https://hydra-prod.duckdns.org'; Write-Host 'Downloading setup.ps1...'; try{iwr -Uri ($u+'/api/workers/setup.ps1') -OutFile $env:TEMP\hydra-setup.ps1 -UseBasicParsing}catch{Write-Host ('Download failed: '+$_) -ForegroundColor Red;pause;exit 1}; & $env:TEMP\hydra-setup.ps1 -Token $t -ServerUrl $u; pause"
