@echo off
powershell -NoProfile -ExecutionPolicy Bypass -Command "if(-not([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)){Start-Process -FilePath '%~f0' -Verb RunAs;exit}; Add-Type -AssemblyName Microsoft.VisualBasic; $t=[Microsoft.VisualBasic.Interaction]::InputBox('어드민에서 발급받은 enrollment token (eyJ...)','HYDRA Worker',''); if([string]::IsNullOrWhiteSpace($t)){Write-Host '[HYDRA] No token entered. Aborted.' -ForegroundColor Yellow; pause; exit 1}; $u='https://hydra-prod.duckdns.org'; Write-Host '[HYDRA] Token received. Downloading setup.ps1...'; try{iwr -Uri ($u+'/api/workers/setup.ps1') -OutFile $env:TEMP\hydra-setup.ps1 -UseBasicParsing}catch{Write-Host ('[HYDRA] Download failed: '+$_) -ForegroundColor Red; pause; exit 1}; & $env:TEMP\hydra-setup.ps1 -Token $t -ServerUrl $u; pause"
