powershell -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference='Stop'; $log=$env:TEMP+'\hydra-install.log'; Start-Transcript -Path $log -Append | Out-Null; try { Write-Host '[1] start'; if(-not([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)){ Write-Host '[2] not admin, elevating via UAC'; Start-Process -FilePath '%~f0' -Verb RunAs; exit }; Write-Host '[3] admin OK, opening InputBox'; Add-Type -AssemblyName Microsoft.VisualBasic; $t=[Microsoft.VisualBasic.Interaction]::InputBox('Paste enrollment token (eyJ...)','HYDRA Worker',''); Write-Host ('[4] InputBox closed, token length=' + $t.Length); if([string]::IsNullOrWhiteSpace($t)){ Write-Host '[X] empty token, abort' -ForegroundColor Yellow; pause; exit 1 }; $u='https://hydra-prod.duckdns.org'; $sp=$env:TEMP+'\hydra-setup.ps1'; Write-Host '[5] downloading setup.ps1'; iwr -Uri ($u+'/api/workers/setup.ps1') -OutFile $sp -UseBasicParsing; Write-Host ('[6] download OK, size=' + (Get-Item $sp).Length + ' bytes'); Write-Host '[7] running setup.ps1'; & $sp -Token $t -ServerUrl $u; Write-Host '[8] setup.ps1 finished' } catch { Write-Host ''; Write-Host '[ERROR] ' -ForegroundColor Red -NoNewline; Write-Host $_.Exception.Message -ForegroundColor Red; Write-Host $_.ScriptStackTrace -ForegroundColor DarkGray } finally { Stop-Transcript | Out-Null; Write-Host ''; Write-Host ('log: ' + $log) -ForegroundColor Cyan; Write-Host 'press ENTER to close'; pause }"
